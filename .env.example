# =============================================================================
# ScreenAI — Environment Variables
# Copy this file to .env (development) or .env.production (production)
# =============================================================================

# --- DeepSeek LLM ---
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Database ---
# Development (SQLite)
DATABASE_URL=sqlite:///./data/app.db

# Production (PostgreSQL) — uncomment and fill for production
# DATABASE_URL=postgresql://screenai:your-password@db:5432/screenai
# DB_USER=screenai
# DB_PASSWORD=your-strong-password-here
# DB_NAME=screenai

# --- Auth ---
SECRET_KEY=dev-secret-change-me-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Email (Resend) ---
# Leave empty in dev — verification link will print to console instead
RESEND_API_KEY=
EMAIL_FROM=noreply@screenai.my.id
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# --- App ---
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
ALLOWED_ORIGINS=

# --- Production only ---
# FRONTEND_URL=https://screenai.my.id
# ENVIRONMENT=production
# ALLOWED_ORIGINS=https://screenai.my.id
